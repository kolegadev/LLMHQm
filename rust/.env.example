# LLMHQ Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgres://llmhq:llmhq_pass@localhost:5432/llmhq

# =============================================================================
# POLYMARKET
# =============================================================================
# Market ID for BTC 5-minute prediction market
# Find this on Polymarket Gamma API or UI
POLYMARKET_MARKET_ID=your-btc-5m-market-id

# Optional: Gamma API URL (defaults to production)
# POLYMARKET_API_URL=https://gamma-api.polymarket.com

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Initial paper trading balance
INITIAL_BALANCE=10000

# Minimum confidence threshold (0-100)
MIN_CONFIDENCE=65

# Maximum position size as % of balance
MAX_POSITION_PCT=95

# Odds validation threshold (0.0-1.0)
# YES bets must have odds >= this value
YES_ODDS_THRESHOLD=0.505

# Block interval in minutes (5 or 15)
BLOCK_INTERVAL_MINUTES=5

# =============================================================================
# BINANCE
# =============================================================================
# WebSocket endpoints (defaults are fine for most users)
# BINANCE_SPOT_WS=wss://stream.binance.com:9443/ws
# BINANCE_FUTURES_WS=wss://fstream.binance.com/ws

# =============================================================================
# LOGGING
# =============================================================================
RUST_LOG=info,llmhq=debug

# Optional: Enable JSON logging
# RUST_LOG_FORMAT=json

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable odds validation (recommended)
VALIDATE_ODDS=true

# Enable LLM deep analysis (slower but more thorough)
# ENABLE_LLM_DEEP_THINK=false

# Dry run mode - log decisions but don't execute trades
# DRY_RUN=false
