# LLMHQ Configuration
# Production configuration for BTC 5M market

# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=postgres://llmhq:llmhq_pass@localhost:5432/llmhq

# =============================================================================
# POLYMARKET - BTC 5M Market
# =============================================================================
# Market: BTC UP/DOWN 5M
# URL: https://polymarket.com/event/btc-updown-5m-1773358800
# 
# NOTE: The number at the end (1773358800) is a Unix timestamp.
# Each 5-minute block creates a new market with timestamp += 300
# The system will auto-increment this when block ends.
POLYMARKET_MARKET_BASE=btc-updown-5m
POLYMARKET_MARKET_TIMESTAMP=1773358800
POLYMARKET_BLOCK_DURATION=300

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
INITIAL_BALANCE=10000
MIN_CONFIDENCE=65
MAX_POSITION_PCT=95
YES_ODDS_THRESHOLD=0.505
BLOCK_INTERVAL_MINUTES=5

# =============================================================================
# LOGGING
# =============================================================================
RUST_LOG=info,llmhq=debug

# =============================================================================
# FEATURE FLAGS
# =============================================================================
VALIDATE_ODDS=true
